# Multi-LLM-Nexus — Provider Configuration
# Generated by setup wizard, or copy this file to providers.yaml and edit manually.
#
# ORGANIZATIONAL ROUTING MODEL
# ─────────────────────────────
# Nexus treats providers like company staff. Every provider is a member of one or more
# tier pools (nano / standard / deep). The router selects from the pool — not a fixed
# assignment — using cost-class priority:
#
#   local (electricity-only) → free_limited (rate-limited) → paid_subscription (token cost)
#
# Paid tokens are the provider of last resort. If a local or free-tier provider can handle
# the task, Nexus uses it. Paid providers only activate when cheaper options are exhausted
# or when the task genuinely requires frontier capability.
#
# Each provider requires three additional fields for pool routing:
#   cost_class — local | free_limited | paid_subscription
#   rpm / rpd / tpm / tpd — rate limits (omit or set 0 for unlimited)
#   role — communicator | worker   (default: worker)
#     communicator = a high-trust, stateful provider allowed to produce the
#       USER-FACING answer. Mark your best provider(s) communicator.
#     worker = cheap/stateless; used only for delegated sub-tasks (triage,
#       specialist opinions), NEVER posted to the user directly. A worker can be
#       wrong, but it must never *say* a wrong thing to a user (decision D-009).
#     If NO provider is marked communicator, Nexus falls back to the full pool
#       for user-facing answers (backward compatible) and warns once.
#
# Provider types:
#   claude_code → ClaudeCodeProvider  (CLI, full MCP)
#   anthropic   → AnthropicProvider   (direct API, prompt caching)
#   openai      → OpenAIProvider      (groq, mistral, deepseek, cerebras,
#                                      xai, together, fireworks, perplexity,
#                                      huggingface, azure_openai, lm_studio, vllm)
#   gemini      → GeminiProvider      (AI Studio or Vertex AI)
#   bedrock     → BedrockProvider     (AWS)
#   cohere      → CohereProvider      (Command R / RAG)
#   ollama      → OllamaProvider      (local, zero cost)

providers:

  # ── LOCAL — electricity-only, unlimited, always preferred ──────────────────

  # Nano local model (triage, simple tasks, low latency)
  ollama_nano:
    type: ollama
    model: phi4-mini              # ~1GB RAM, sub-100ms
    endpoint: http://localhost:11434
    cost_class: local             # no rate limits, no token cost
    tier: nano

  # Standard local model (coding, general tasks)
  ollama_standard:
    type: ollama
    model: llama3.1:8b
    endpoint: http://localhost:11434
    cost_class: local
    tier: standard

  # Deep local model (complex reasoning, only if hardware supports it)
  # ollama_deep:
  #   type: ollama
  #   model: llama3.1:70b
  #   endpoint: http://localhost:11434
  #   cost_class: local
  #   tier: deep

  # vLLM server (GPU-backed, multi-GPU tensor parallel)
  # vllm_server:
  #   type: openai
  #   model: meta-llama/Llama-3.1-8B-Instruct
  #   api_key: no-key
  #   base_url: http://localhost:8000/v1
  #   cost_class: local
  #   tier: standard

  # ── FREE-TIER — rate-limited, second preference after local ────────────────

  # Groq — fastest cloud inference (~500 tok/s), generous free tier
  groq:
    type: openai
    model: llama-3.1-8b-instant
    api_key: ${GROQ_API_KEY}
    base_url: https://api.groq.com/openai/v1
    cost_class: free_limited
    tier: nano
    rpm: 30
    rpd: 14400
    tpm: 6000              # tight TPM — biggest constraint on Groq free
    tpd: 500000
    display_prefix: Groq
    model_display: Llama-8B

  # Cerebras — wafer-scale hardware, very fast on supported models
  cerebras:
    type: openai
    model: qwen-3-235b-a22b-instruct-2507
    api_key: ${CEREBRAS_API_KEY}
    base_url: https://api.cerebras.ai/v1
    cost_class: free_limited
    tier: standard
    rpm: 30
    rpd: 14400
    tpm: 60000
    tpd: 1000000           # 1M tokens/day
    display_prefix: Cerebras
    model_display: Qwen3-235B

  # Google Gemini Flash (AI Studio free tier)
  # gemini_flash:
  #   type: gemini
  #   model: gemini-2.0-flash
  #   api_key: ${GOOGLE_API_KEY}
  #   cost_class: free_limited
  #   tier: nano
  #   rpm: 15
  #   rpd: 1500

  # GitHub Models (free with GitHub account, higher limits with Copilot)
  # github_models:
  #   type: openai
  #   model: gpt-4o-mini
  #   api_key: ${GITHUB_TOKEN}
  #   base_url: https://models.inference.ai.azure.com
  #   cost_class: free_limited
  #   tier: nano
  #   rpd: 50

  # HuggingFace Inference (free tier, cold-start latency possible)
  # hf_inference:
  #   type: openai
  #   model: meta-llama/Llama-3.1-8B-Instruct
  #   api_key: ${HF_TOKEN}
  #   base_url: https://api-inference.huggingface.co/v1
  #   cost_class: free_limited
  #   tier: nano
  #   rpd: 1000

  # ── PAID SUBSCRIPTION — token cost, last resort unless task requires it ────

  # Claude Code CLI (subscription, full MCP ecosystem)
  claude_code:
    type: claude_code
    model: claude-sonnet-4-6
    timeout: 600
    cost_class: paid_subscription
    tier: standard
    role: communicator            # answers users directly; workers never do (D-009)
    # effort: low | medium | high  (controls extended thinking)

  # Anthropic direct API (no CLI required)
  # claude_sonnet:
  #   type: anthropic
  #   model: claude-sonnet-4-6
  #   api_key: ${ANTHROPIC_API_KEY}
  #   prompt_caching: true
  #   cost_class: paid_subscription
  #   tier: standard

  # claude_opus:
  #   type: anthropic
  #   model: claude-opus-4-7
  #   api_key: ${ANTHROPIC_API_KEY}
  #   prompt_caching: true
  #   cost_class: paid_subscription
  #   tier: deep

  # OpenAI
  # openai_standard:
  #   type: openai
  #   model: gpt-4o
  #   api_key: ${OPENAI_API_KEY}
  #   cost_class: paid_subscription
  #   tier: standard

  # openai_deep:
  #   type: openai
  #   model: o3
  #   api_key: ${OPENAI_API_KEY}
  #   cost_class: paid_subscription
  #   tier: deep

  # Perplexity — live web search, use as research specialist
  # perplexity_search:
  #   type: openai
  #   model: llama-3.1-sonar-large-128k-online
  #   api_key: ${PERPLEXITY_API_KEY}
  #   base_url: https://api.perplexity.ai
  #   cost_class: paid_subscription
  #   tier: standard

  # DeepSeek — very low cost, R1 reasoning available
  # deepseek_standard:
  #   type: openai
  #   model: deepseek-chat
  #   api_key: ${DEEPSEEK_API_KEY}
  #   base_url: https://api.deepseek.com/v1
  #   cost_class: paid_subscription
  #   tier: standard

  # Mistral — EU-hosted, GDPR-friendly
  # mistral_eu:
  #   type: openai
  #   model: mistral-large-latest
  #   api_key: ${MISTRAL_API_KEY}
  #   base_url: https://api.mistral.ai/v1
  #   cost_class: paid_subscription
  #   tier: deep

  # Cohere — best for RAG/retrieval-heavy workflows
  # cohere_rag:
  #   type: cohere
  #   model: command-r-plus
  #   api_key: ${COHERE_API_KEY}
  #   cost_class: paid_subscription
  #   tier: standard

  # Amazon Bedrock (Claude + Llama + Mistral under your AWS bill)
  # bedrock_claude:
  #   type: bedrock
  #   model: anthropic.claude-3-5-sonnet-20241022-v2:0
  #   region: us-east-1
  #   cost_class: paid_subscription
  #   tier: standard

  # Azure OpenAI (enterprise, data residency)
  # azure_gpt4o:
  #   type: openai
  #   model: gpt-4o
  #   api_key: ${AZURE_OPENAI_API_KEY}
  #   base_url: ${AZURE_OPENAI_ENDPOINT}
  #   api_version: "2024-02-01"
  #   cost_class: paid_subscription
  #   tier: standard


# ── Tier Pools ────────────────────────────────────────────────────────────────
# Define which providers belong to each tier.
# Providers are tried in cost-class priority order: local → free → paid.
# Parallel dispatch, failover, and load distribution happen automatically.
#
# Add a provider to multiple pools if it can serve multiple tiers.
# Comment out any pool you don't need — routing falls back to default_pool.

tier_pools:

  nano:
    # Fast, cheap triage and simple tasks. Prefer local, then free-tier.
    providers:
      - ollama_nano       # local: always first
      - groq              # free: fast fallback
      - cerebras          # free: large model fallback
      - claude_code       # paid: last resort
    parallelism: sequential    # sequential | failover | parallel
    capability_tags: [general, code]

  standard:
    # Most work happens here. Prefer local, then free.
    providers:
      - ollama_standard   # local: always first
      - cerebras          # free: solid standard-tier model
      - claude_code       # paid: brings in frontier when needed
    parallelism: failover
    capability_tags: [general, code, reasoning]

  deep:
    # Complex analysis, architecture decisions, long reasoning chains.
    providers:
      - claude_code       # paid: frontier capability
      # - claude_opus     # uncomment for heavier deep tasks
      # - openai_deep     # o3 for reasoning-heavy tasks
    parallelism: sequential
    capability_tags: [reasoning, code, deep_analysis]

  # Specialist pools — uncomment when you add the corresponding providers
  # research:
  #   providers:
  #     - perplexity_search   # live web search
  #     - claude_code         # synthesis
  #   parallelism: sequential
  #   capability_tags: [search, reasoning]

  # code:
  #   providers:
  #     - ollama_standard     # local code model (e.g. deepseek-coder)
  #     - cerebras            # fast free-tier fallback
  #     - claude_code         # frontier when needed
  #   parallelism: failover
  #   capability_tags: [code]


# ── Failover chain config (used if tier_pools is not defined) ─────────────────
# Legacy single-provider failover — preserved for backward compatibility.
# If tier_pools is defined above, this section is ignored for pool routing.
failover:
  strategy: priority
  health_check_interval: 60
  retry_attempts: 3
  retry_delay: 0.5
  failure_threshold: 3
  cooldown_seconds: 30.0
  on_failure: next_available
  enable_health_monitoring: true


# ── Routing ───────────────────────────────────────────────────────────────────
routing:
  # Pool-based routing (used when tier_pools is defined)
  default_pool: standard        # pool to use when no specific match
  triage_pool: nano             # pool for classifying incoming messages
  code_pool: standard           # pool for code tasks
  research_pool: deep           # pool for research/analysis tasks
  deep_pool: deep               # pool for complex reasoning
  fallback: claude_code         # absolute last resort if all pools fail

  # Legacy single-provider routing (used when tier_pools is NOT defined)
  # Uncomment these and comment out the pool settings above to use legacy mode:
  # default: claude_code
  # triage: groq
  # local_offload: false
  # local: ollama_nano
