# Multi-LLM-Nexus — Provider Configuration
# Generated by setup wizard, or copy this file to providers.yaml and edit manually.
# The router uses this to decide which LLM handles each task type.
#
# Provider types and the class they use:
#   claude_code   → ClaudeCodeProvider  (CLI, full MCP)
#   anthropic     → AnthropicProvider   (direct API, prompt caching)
#   openai        → OpenAIProvider      (also: groq, mistral, deepseek, xai,
#                                        together, fireworks, perplexity,
#                                        huggingface, cerebras, azure_openai,
#                                        lm_studio, vllm — set base_url)
#   gemini        → GeminiProvider      (AI Studio or Vertex AI)
#   bedrock       → BedrockProvider     (AWS, multiple model families)
#   cohere        → CohereProvider      (Command R / RAG)
#   ollama        → OllamaProvider      (local, zero cost)

providers:

  # ── Primary — handles most conversations ───────────────────────────────

  primary:
    type: claude_code
    model: claude-sonnet-4-6
    timeout: 600
    # effort: low | medium | high   (claude_code only — controls extended thinking)

  # ── Triage — classifies every message; must be fast and cheap ──────────
  # Fires before routing. If omitted, keyword heuristics are used instead.

  triage:
    type: ollama
    model: phi4-mini                   # ~1GB, sub-100ms, free
    endpoint: http://localhost:11434
    # Alternative: Groq is the best cloud triage option
    # type: openai
    # model: llama-3.1-8b-instant
    # api_key: ${GROQ_API_KEY}
    # base_url: https://api.groq.com/openai/v1

  # ── Local / privacy — nothing leaves the network ───────────────────────

  privacy:
    type: ollama
    model: llama3.1:8b
    endpoint: http://localhost:11434

  # ── Examples: cloud providers (uncomment and fill in) ──────────────────

  # Anthropic direct API (no CLI required)
  # anthropic_direct:
  #   type: anthropic
  #   model: claude-sonnet-4-6
  #   api_key: ${ANTHROPIC_API_KEY}
  #   prompt_caching: true

  # OpenAI
  # openai_standard:
  #   type: openai
  #   model: gpt-4o
  #   api_key: ${OPENAI_API_KEY}

  # Google Gemini (AI Studio — free tier at aistudio.google.com)
  # gemini_flash:
  #   type: gemini
  #   model: gemini-2.0-flash
  #   api_key: ${GOOGLE_API_KEY}

  # Groq — fastest cloud inference (~500 tok/s), free tier
  # groq_fast:
  #   type: openai
  #   model: llama-3.1-8b-instant
  #   api_key: ${GROQ_API_KEY}
  #   base_url: https://api.groq.com/openai/v1

  # Mistral — EU-hosted, GDPR-friendly
  # mistral_eu:
  #   type: openai
  #   model: mistral-large-latest
  #   api_key: ${MISTRAL_API_KEY}
  #   base_url: https://api.mistral.ai/v1

  # DeepSeek — very low cost, R1 reasoning available
  # deepseek_standard:
  #   type: openai
  #   model: deepseek-chat
  #   api_key: ${DEEPSEEK_API_KEY}
  #   base_url: https://api.deepseek.com/v1
  # deepseek_reason:
  #   type: openai
  #   model: deepseek-reasoner
  #   api_key: ${DEEPSEEK_API_KEY}
  #   base_url: https://api.deepseek.com/v1

  # xAI / Grok
  # grok:
  #   type: openai
  #   model: grok-2
  #   api_key: ${XAI_API_KEY}
  #   base_url: https://api.x.ai/v1

  # Cohere — best for RAG / retrieval-heavy workflows
  # cohere_rag:
  #   type: cohere
  #   model: command-r-plus
  #   api_key: ${COHERE_API_KEY}

  # Perplexity — live web search built into every response
  # perplexity_search:
  #   type: openai
  #   model: llama-3.1-sonar-large-128k-online
  #   api_key: ${PERPLEXITY_API_KEY}
  #   base_url: https://api.perplexity.ai

  # Together.ai — 50+ open-source models
  # together_llama:
  #   type: openai
  #   model: meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
  #   api_key: ${TOGETHER_API_KEY}
  #   base_url: https://api.together.xyz/v1

  # Hugging Face Inference (free tier)
  # hf_inference:
  #   type: openai
  #   model: meta-llama/Llama-3.1-8B-Instruct
  #   api_key: ${HF_TOKEN}
  #   base_url: https://api-inference.huggingface.co/v1

  # Cerebras — wafer-chip inference, very fast
  # cerebras_fast:
  #   type: openai
  #   model: llama3.1-70b
  #   api_key: ${CEREBRAS_API_KEY}
  #   base_url: https://api.cerebras.ai/v1

  # ── Cloud infrastructure providers ─────────────────────────────────────

  # Amazon Bedrock (Claude + Llama + Mistral under your AWS bill)
  # bedrock_claude:
  #   type: bedrock
  #   model: anthropic.claude-3-5-sonnet-20241022-v2:0
  #   region: us-east-1
  #   # profile: default              # use a named AWS profile
  #   # access_key: ${AWS_ACCESS_KEY_ID}
  #   # secret_key: ${AWS_SECRET_ACCESS_KEY}

  # Azure OpenAI (enterprise, data residency)
  # azure_gpt4o:
  #   type: openai
  #   model: gpt-4o                  # your Azure deployment name
  #   api_key: ${AZURE_OPENAI_API_KEY}
  #   base_url: ${AZURE_OPENAI_ENDPOINT}
  #   api_version: "2024-02-01"

  # Google Vertex AI (GCP project)
  # vertex_pro:
  #   type: vertex_ai
  #   model: gemini-1.5-pro
  #   project: ${GOOGLE_CLOUD_PROJECT}
  #   region: us-central1

  # ── Local self-hosted providers ─────────────────────────────────────────

  # LM Studio (GUI model manager + local OpenAI-compatible API)
  # lm_studio_local:
  #   type: openai
  #   model: local-model             # matches whatever model LM Studio has loaded
  #   api_key: no-key
  #   base_url: http://localhost:1234/v1

  # vLLM (self-hosted, GPU server)
  # vllm_server:
  #   type: openai
  #   model: meta-llama/Llama-3.1-8B-Instruct
  #   api_key: no-key
  #   base_url: http://localhost:8000/v1


routing:
  default: primary          # fallback provider for unmatched messages
  triage: triage            # provider used to classify every incoming message

  # Pattern matching — first match wins. Uses Python regex, case-insensitive.
  patterns:
    - match: "code|debug|fix|script|implement|refactor"
      provider: primary
    - match: "private|sensitive|local only|confidential"
      provider: privacy
    # Uncomment to route web-search queries to Perplexity:
    # - match: "search|latest|current|today|news"
    #   provider: perplexity_search
    # Uncomment to route RAG/document queries to Cohere:
    # - match: "document|retrieve|find in|search my"
    #   provider: cohere_rag
