# Multi-LLM-Nexus — Adapter Configuration
# Copy to config/adapters.yaml and fill in your values.
# Enable only the platforms you use. Disable with: enabled: false

# ── Global settings ───────────────────────────────────────────────────────────

# Name your Chief of Staff — shown in status messages and startup announcements
bot_name: Nexus

# System prompt injected at the start of every new conversation.
# Use this to establish persona, operating context, and ground rules.
system_prompt: |
  You are Nexus, a capable AI assistant. You help with tasks, answer questions,
  and maintain context across a conversation. You are direct and concise.

# Map channel/context names to directories on disk.
# Name these whatever fits your domain — projects, experiments, clients, etc.
channel_map:
  general: ~/work/general
  # my-project: ~/work/my-project

# Base working directory — where Nexus looks for channel-mapped folders.
# Defaults to the service account's home directory if not set.
workdir: ~/work

# ── Mattermost ────────────────────────────────────────────────────────────────
mattermost:
  enabled: true
  url: http://localhost:8065/api/v4     # Mattermost server API base URL
  token: ${MATTERMOST_BOT_TOKEN}        # Bot token from Mattermost admin console
  team: main                            # Team name (not display name)
  allowed_user: ""                      # Restrict to one username, or leave blank for all
  # allowed_users:                      # For multi-user allowlisting (future)
  #   - alice
  #   - bob

# ── Discord ───────────────────────────────────────────────────────────────────
discord:
  enabled: false
  token: ${DISCORD_BOT_TOKEN}           # Discord bot token from Discord Developer Portal
  channel_id: ""                        # Channel ID to monitor (right-click → Copy ID)
  allowed_users: []                     # Discord user IDs to accept messages from (integers)
                                        # Leave empty to accept from all non-bot users
  poll_interval: 10                     # Seconds between REST polls (Discord has no websocket push)

# ── Telegram ──────────────────────────────────────────────────────────────────
telegram:
  enabled: false
  token: ${TELEGRAM_BOT_TOKEN}          # Bot token from @BotFather
  allowed_users: []                     # Telegram user IDs (integers) — empty = all
  chat_id: null                         # Optional: restrict to one specific chat/group ID

# ── Slack ─────────────────────────────────────────────────────────────────────
# Note: Slack adapter not yet implemented — config reserved for future use
slack:
  enabled: false
  bot_token: ${SLACK_BOT_TOKEN}         # Bot User OAuth Token (xoxb-...)
  app_token: ${SLACK_APP_TOKEN}         # App-Level Token for Socket Mode (xapp-...)
  allowed_users: []                     # Slack user IDs to accept messages from

# ── Matrix ────────────────────────────────────────────────────────────────────
# Note: Matrix adapter not yet implemented — config reserved for future use
matrix:
  enabled: false
  homeserver: https://matrix.org
  user_id: "@yourbot:matrix.org"
  access_token: ${MATRIX_ACCESS_TOKEN}
  rooms: []                             # Room IDs to join and monitor

# ── OpenAI-compatible HTTP API ────────────────────────────────────────────────
# Exposes /v1/chat/completions and /v1/models so any OpenAI-compatible tool
# (VS Code Continue.dev, Cursor, Open WebUI, etc.) can use Nexus as its
# AI provider. Routing, failover, and specialist dispatch are transparent.
#
# Model names → Nexus tiers:
#   nexus           auto-routed (triage decides)
#   nexus-nano      TIER_NANO  (fast / cheap)
#   nexus-standard  TIER_STANDARD
#   nexus-deep      TIER_DEEP  (most capable)
#
# In Continue.dev config (replace <nexus-host> with the IP of the machine
# running Nexus — e.g. 10.0.0.7 if Nexus is on a separate VM):
#   { "provider": "openai", "model": "nexus",
#     "apiBase": "http://<nexus-host>:8080/v1", "apiKey": "nexus" }
#
# If VS Code and Nexus are on different machines, set host: 0.0.0.0
# so the adapter binds on all interfaces (not just loopback).
openai_api:
  enabled: false
  host: 0.0.0.0     # 0.0.0.0 = LAN-accessible | 127.0.0.1 = local only
  port: 8080
  api_key: ""        # Optional Bearer token. Leave blank to disable auth.

# ── User Gate — Per-adapter access control ────────────────────────────────────
# Applies to any adapter that has multi-user exposure (Discord, Telegram, etc).
# The gate runs BEFORE any LLM call — zero token cost for denied messages.
#
# Two-stage check:
#   Stage 1: ACL lookup + regex hard-deny (instant, 0 cost)
#   Stage 2: Local LLM intent classification (nano tier, ~50ms, 0 cloud cost)
#
# Intent categories for allow/deny:
#   chat            — general conversation, questions
#   research        — search, look up, explain topics
#   code            — write/debug/review code
#   system          — server/service status queries
#   admin           — deploy, restart, config changes
#   file_access     — read files, list directories
#   code_execution  — run scripts, shell access
#
# default_user_scope: deny  → unknown users are silently dropped
# default_user_scope: allow → unknown users pass Stage 2 intent checks
#
# scope: all → operator access, bypasses all checks instantly
# allow: [list] → only these intents allowed (whitelist)
# deny: [list]  → these intents blocked (blacklist)
# Both can be combined: deny takes priority over allow.
#
# Example — Discord with multi-user access:
# discord:
#   enabled: true
#   token: ${DISCORD_BOT_TOKEN}
#   channel_id: 123456789012345678
#   default_user_scope: deny
#   rate_limit:
#     window_seconds: 60
#     max_messages: 10
#   users:
#     "151160889318309889":        # operator — unrestricted
#       scope: all
#     "987654321000000000":        # trusted user — research only
#       allow: [research, chat]
#       deny: [system, admin, file_access, code_execution]
#       rate_limit:
#         window_seconds: 60
#         max_messages: 5
#
# Mattermost (single-user or trusted team — gate disabled by default):
# mattermost:
#   enabled: true
#   token: ${MATTERMOST_BOT_TOKEN}
#   url: http://localhost:8065/api/v4
#   team: main
#   allowed_user: ${MATTERMOST_ALLOWED_USER}
#   default_user_scope: allow      # MM is already filtered by allowed_user
#   users:
#     "${MATTERMOST_ALLOWED_USER}":
#       scope: all
