# Multi-LLM-Nexus — Environment Variables
# Copy to .env and fill in what you use — never commit .env to git
#
# You only need the keys for the providers you configure.
# The setup wizard (python -m src.setup.wizard) will tell you exactly which ones.

# ── Nexus Identity ────────────────────────────────────────────────────────────
NEXUS_AGENT_NAME=Nexus          # name of your Chief of Staff
NEXUS_OPERATOR_NAME=Operator    # your name / handle

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Google Gemini (AI Studio) ─────────────────────────────────────────────────
GOOGLE_API_KEY=

# ── Google Vertex AI ──────────────────────────────────────────────────────────
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1
# Auth via: gcloud auth application-default login
# or set GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Groq ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=

# ── Mistral ───────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=

# ── DeepSeek ──────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=

# ── xAI (Grok) ───────────────────────────────────────────────────────────────
XAI_API_KEY=

# ── Together AI ───────────────────────────────────────────────────────────────
TOGETHER_API_KEY=

# ── Fireworks AI ──────────────────────────────────────────────────────────────
FIREWORKS_API_KEY=

# ── Perplexity ────────────────────────────────────────────────────────────────
PERPLEXITY_API_KEY=

# ── HuggingFace (Inference API) ───────────────────────────────────────────────
HUGGINGFACE_API_KEY=

# ── Cerebras ──────────────────────────────────────────────────────────────────
CEREBRAS_API_KEY=

# ── Cohere ────────────────────────────────────────────────────────────────────
COHERE_API_KEY=

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
# Or use a named profile (set in providers.yaml): AWS_PROFILE=my-profile
# Or use IAM role — no keys needed if running on EC2/ECS/Lambda

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ── Ollama (local — no key needed) ────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434/v1   (override only if not default)

# ── LM Studio (local — no key needed) ────────────────────────────────────────
# LM_STUDIO_BASE_URL=http://localhost:1234/v1  (override only if not default)

# ── vLLM (self-hosted — no key needed) ───────────────────────────────────────
# VLLM_BASE_URL=http://localhost:8000/v1       (override only if not default)

# ── Platform Adapters ─────────────────────────────────────────────────────────
MATTERMOST_BOT_TOKEN=
DISCORD_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
MATRIX_ACCESS_TOKEN=
